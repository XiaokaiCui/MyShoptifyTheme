{%- style -%}
  .newsletter-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    text-align: center;
  }
  
  .newsletter__container {
    max-width: 600px;
    margin: 0 auto;
  }
  
  .newsletter__icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.icon_background }};
    border-radius: 50%;
    color: {{ section.settings.icon_color }};
    font-size: 1.5rem;
  }
  
  .newsletter__title {
    font-family: var(--font-heading-family);
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.text_color }};
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  
  .newsletter__subtitle {
    font-family: var(--font-body-family);
    font-size: {{ section.settings.subtitle_size }}px;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }
  
  .newsletter__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 400px;
    margin: 0 auto;
  }
  
  .newsletter__input {
    padding: 1rem 1.5rem;
    border: 2px solid {{ section.settings.border_color }};
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ section.settings.text_color }};
    background-color: {{ section.settings.input_background }};
    transition: all 0.3s ease;
  }
  
  .newsletter__input:focus {
    outline: none;
    border-color: {{ section.settings.accent_color }};
    box-shadow: 0 0 0 3px rgba(232, 180, 184, 0.1);
  }
  
  .newsletter__input::placeholder {
    color: {{ section.settings.text_color }};
    opacity: 0.5;
  }
  
  .newsletter__button {
    padding: 1rem 1.5rem;
    background-color: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color }};
    border: none;
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .newsletter__button:hover {
    background-color: {{ section.settings.button_hover_color }};
    transform: translateY(-2px);
  }
  
  .newsletter__disclaimer {
    font-family: var(--font-body-family);
    font-size: 0.85rem;
    color: {{ section.settings.text_color }};
    opacity: 0.6;
    margin-top: 1.5rem;
    line-height: 1.5;
  }
  
  .newsletter__success {
    display: none;
    padding: 2rem;
    background-color: {{ section.settings.success_background }};
    border-radius: 12px;
    color: {{ section.settings.success_text_color }};
    font-family: var(--font-body-family);
    font-size: 1rem;
    line-height: 1.6;
    margin-top: 2rem;
  }
  
  .newsletter__success.show {
    display: block;
  }
  
  @media screen and (max-width: 768px) {
    .newsletter-{{ section.id }} {
      padding: {{ section.settings.padding_top_mobile }}px 1rem {{ section.settings.padding_bottom_mobile }}px;
    }
    
    .newsletter__title {
      font-size: calc({{ section.settings.title_size }}px * 0.8);
    }
    
    .newsletter__subtitle {
      font-size: calc({{ section.settings.subtitle_size }}px * 0.9);
    }
    
    .newsletter__form {
      max-width: 100%;
    }
  }
{%- endstyle -%}

<div class="newsletter newsletter-{{ section.id }}">
  <div class="newsletter__container">
    <div class="newsletter__icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
    </div>
    
    {%- if section.settings.title != blank -%}
      <h2 class="newsletter__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    
    {%- if section.settings.subtitle != blank -%}
      <p class="newsletter__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    
    {%- form 'customer', class: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      
      <div class="newsletter__form">
        <input
          type="email"
          name="contact[email]"
          class="newsletter__input"
          value="{{ form.email }}"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          {% if form.errors %}
            autofocus
            aria-invalid="true"
            aria-describedby="Newsletter-error--{{ section.id }}"
          {% elsif form.posted_successfully? %}
            aria-describedby="Newsletter-success--{{ section.id }}"
          {% endif %}
          placeholder="{{ section.settings.placeholder }}"
          required
        >
        
        <button type="submit" class="newsletter__button" name="commit">
          {{ section.settings.button_label }}
        </button>
      </div>
      
      {%- if form.errors -%}
        <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
          {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
        </small>
      {%- endif -%}
    {%- endform -%}
    
    {%- if form.posted_successfully? -%}
      <div class="newsletter__success show" id="Newsletter-success--{{ section.id }}" role="status">
        {{ section.settings.success_message }}
      </div>
    {%- endif -%}
    
    {%- if section.settings.disclaimer != blank -%}
      <p class="newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const newsletterForm = document.querySelector('.newsletter-form');
    const successMessage = document.querySelector('.newsletter__success');
    
    if (newsletterForm) {
      newsletterForm.addEventListener('submit', function(e) {
        // In a real implementation, this would be handled by Shopify
        // For demo purposes, we'll show the success message
        setTimeout(function() {
          if (successMessage) {
            successMessage.classList.add('show');
          }
        }, 1000);
      });
    }
  });
</script>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join Our Cozy Community"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Be the first to know about new collections, special offers, and behind-the-scenes stories."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder text",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for subscribing! Check your email for a welcome message."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "We respect your privacy. Unsubscribe at any time."
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 36
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 16
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#E8B4B8"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "input_background",
      "label": "Input background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#E8B4B8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#E8B4B8"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#E8B4B8"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#C97C8D"
    },
    {
      "type": "color",
      "id": "success_background",
      "label": "Success background",
      "default": "#B5C2B7"
    },
    {
      "type": "color",
      "id": "success_text_color",
      "label": "Success text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "settings": {
        "title": "Join Our Cozy Community",
        "subtitle": "Be the first to know about new collections, special offers, and behind-the-scenes stories.",
        "button_label": "Subscribe"
      }
    }
  ]
}
{% endschema %}