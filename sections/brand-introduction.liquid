{%- style -%}
  .brand-intro-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }
  
  .brand-intro__container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  
  .brand-intro__title {
    font-family: var(--font-heading-family);
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.text_color }};
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }
  
  .brand-intro__content {
    font-family: var(--font-body-family);
    font-size: {{ section.settings.content_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.8;
    opacity: 0.9;
  }
  
  .brand-intro__content p {
    margin-bottom: 1.5rem;
  }
  
  .brand-intro__content p:last-child {
    margin-bottom: 0;
  }
  
  @media screen and (max-width: 768px) {
    .brand-intro-{{ section.id }} {
      padding: {{ section.settings.padding_top_mobile }}px 1rem {{ section.settings.padding_bottom_mobile }}px;
    }
    
    .brand-intro__title {
      font-size: calc({{ section.settings.title_size }}px * 0.8);
    }
    
    .brand-intro__content {
      font-size: calc({{ section.settings.content_size }}px * 0.9);
    }
  }
{%- endstyle -%}

<div class="brand-intro brand-intro-{{ section.id }}">
  <div class="brand-intro__container">
    {%- if section.settings.title != blank -%}
      <h2 class="brand-intro__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    
    {%- if section.settings.content != blank -%}
      <div class="brand-intro__content">
        {{ section.settings.content }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Brand Introduction",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Our Story, Stitch by Stitch"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Every piece begins with a story—a quiet moment, a memory, a feeling we want to capture. We believe that handmade items carry more than just thread; they carry intention, care, and a little piece of the maker's heart.</p><p>Inspired by the gentle transition between seasons—the soft light of late spring, the first warmth of early summer—our designs are meant to be lived in, loved, and passed along as heirlooms of modern craftsmanship.</p>"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 32
    },
    {
      "type": "range",
      "id": "content_size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Content size",
      "default": 18
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F8F5F0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Brand Introduction",
      "settings": {
        "title": "Our Story, Stitch by Stitch",
        "content": "<p>Every piece begins with a story—a quiet moment, a memory, a feeling we want to capture. We believe that handmade items carry more than just thread; they carry intention, care, and a little piece of the maker's heart.</p><p>Inspired by the gentle transition between seasons—the soft light of late spring, the first warmth of early summer—our designs are meant to be lived in, loved, and passed along as heirlooms of modern craftsmanship.</p>"
      }
    }
  ]
}
{% endschema %}