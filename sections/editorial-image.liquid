{%- style -%}
  .editorial-{{ section.id }} {
    position: relative;
    min-height: {{ section.settings.height_desktop }}vh;
    overflow: hidden;
  }
  
  @media screen and (max-width: 768px) {
    .editorial-{{ section.id }} {
      min-height: {{ section.settings.height_mobile }}vh;
    }
  }
  
  .editorial__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  
  .editorial__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity }};
    z-index: 2;
  }
  
  .editorial__content {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 2rem;
  }
  
  .editorial__text-container {
    max-width: 600px;
    padding: 3rem;
    background-color: {{ section.settings.text_background }};
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }
  
  .editorial__title {
    font-family: var(--font-heading-family);
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.text_color }};
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }
  
  .editorial__content-text {
    font-family: var(--font-body-family);
    font-size: {{ section.settings.content_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.8;
    opacity: 0.9;
  }
  
  .editorial__content-text p {
    margin-bottom: 1.5rem;
  }
  
  .editorial__content-text p:last-child {
    margin-bottom: 0;
  }
  
  .editorial__button {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.75rem 2rem;
    background-color: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 500;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }
  
  .editorial__button:hover {
    background-color: {{ section.settings.button_hover_color }};
    transform: translateY(-2px);
  }
  
  @media screen and (max-width: 768px) {
    .editorial__content {
      padding: 0 1rem;
    }
    
    .editorial__text-container {
      padding: 2rem;
      margin: 2rem auto;
    }
    
    .editorial__title {
      font-size: calc({{ section.settings.title_size }}px * 0.8);
    }
    
    .editorial__content-text {
      font-size: calc({{ section.settings.content_size }}px * 0.9);
    }
  }
  
  @media screen and (max-width: 480px) {
    .editorial__text-container {
      padding: 1.5rem;
    }
  }
{%- endstyle -%}

<div class="editorial editorial-{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.image.alt | escape }}"
      class="editorial__image"
      loading="lazy"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}"
    >
  {%- else -%}
    <div class="editorial__image placeholder-background" style="background: linear-gradient(135deg, #B5C2B7 0%, #D4E4F7 100%);">
      <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: white; font-size: 1.5rem;">
        Handmade with Care
      </div>
    </div>
  {%- endif -%}
  
  <div class="editorial__overlay"></div>
  
  <div class="editorial__content">
    <div class="editorial__text-container">
      {%- if section.settings.title != blank -%}
        <h2 class="editorial__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      
      {%- if section.settings.content != blank -%}
        <div class="editorial__content-text">
          {{ section.settings.content }}
        </div>
      {%- endif -%}
      
      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="editorial__button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Editorial Image",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Stories You Can Wear and Hold"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>In a world of fast fashion and mass production, we choose a different path. Each piece in our collection begins as a quiet idea—a memory of spring light, the feeling of a favorite story, the gentle curve of a bird's wing.</p><p>We believe that the things we surround ourselves with should carry meaning. That's why every stitch is placed with intention, every color chosen with care, every design born from a story worth telling.</p><p>These aren't just products. They're companions for your journey, heirlooms in the making, tangible pieces of beauty for your everyday life.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Desktop height",
      "default": 70
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 40,
      "max": 90,
      "step": 5,
      "unit": "vh",
      "label": "Mobile height",
      "default": 60
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 32
    },
    {
      "type": "range",
      "id": "content_size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Content size",
      "default": 18
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 30
    },
    {
      "type": "color",
      "id": "text_background",
      "label": "Text background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#E8B4B8"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#C97C8D"
    }
  ],
  "presets": [
    {
      "name": "Editorial Image",
      "settings": {
        "title": "Stories You Can Wear and Hold",
        "content": "<p>In a world of fast fashion and mass production, we choose a different path. Each piece in our collection begins as a quiet idea—a memory of spring light, the feeling of a favorite story, the gentle curve of a bird's wing.</p><p>We believe that the things we surround ourselves with should carry meaning. That's why every stitch is placed with intention, every color chosen with care, every design born from a story worth telling.</p><p>These aren't just products. They're companions for your journey, heirlooms in the making, tangible pieces of beauty for your everyday life.</p>",
        "button_label": "Read Our Story"
      }
    }
  ]
}
{% endschema %}