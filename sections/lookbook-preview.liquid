{%- style -%}
  .lookbook-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }
  
  .lookbook__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .lookbook__title {
    font-family: var(--font-heading-family);
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.text_color }};
    margin-bottom: 1rem;
  }
  
  .lookbook__subtitle {
    font-family: var(--font-body-family);
    font-size: {{ section.settings.subtitle_size }}px;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .lookbook__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .lookbook-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    height: 400px;
    transition: transform 0.3s ease;
  }
  
  .lookbook-item:hover {
    transform: translateY(-5px);
  }
  
  .lookbook-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .lookbook-item:hover .lookbook-item__image {
    transform: scale(1.05);
  }
  
  .lookbook-item__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, 0.3) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 2rem;
  }
  
  .lookbook-item__content {
    color: white;
    width: 100%;
  }
  
  .lookbook-item__title {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  
  .lookbook-item__description {
    font-family: var(--font-body-family);
    font-size: 1rem;
    opacity: 0.9;
    line-height: 1.5;
  }
  
  .lookbook__button-container {
    text-align: center;
    margin-top: 3rem;
  }
  
  .lookbook__button {
    display: inline-block;
    padding: 0.75rem 2rem;
    background-color: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 500;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }
  
  .lookbook__button:hover {
    background-color: {{ section.settings.button_hover_color }};
    transform: translateY(-2px);
  }
  
  @media screen and (max-width: 768px) {
    .lookbook-{{ section.id }} {
      padding: {{ section.settings.padding_top_mobile }}px 1rem {{ section.settings.padding_bottom_mobile }}px;
    }
    
    .lookbook__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .lookbook-item {
      height: 300px;
    }
  }
{%- endstyle -%}

<div class="lookbook lookbook-{{ section.id }}">
  <div class="lookbook__header">
    {%- if section.settings.title != blank -%}
      <h2 class="lookbook__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    
    {%- if section.settings.subtitle != blank -%}
      <p class="lookbook__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>
  
  <div class="lookbook__grid">
    {%- for block in section.blocks -%}
      <div class="lookbook-item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="lookbook-item__image"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {%- else -%}
          <div class="lookbook-item__image placeholder-background" style="background: linear-gradient(135deg, #FFE5D4 0%, #E8B4B8 100%);">
            <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: white; font-size: 1.2rem;">
              {{ block.settings.title | default: 'Lookbook Image' }}
            </div>
          </div>
        {%- endif -%}
        
        <div class="lookbook-item__overlay">
          <div class="lookbook-item__content">
            {%- if block.settings.title != blank -%}
              <h3 class="lookbook-item__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            
            {%- if block.settings.description != blank -%}
              <p class="lookbook-item__description">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
  
  {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
    <div class="lookbook__button-container">
      <a href="{{ section.settings.button_link }}" class="lookbook__button">
        {{ section.settings.button_label }}
      </a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Lookbook Preview",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Lookbook"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "See our pieces in real life, styled with care and intention"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View Full Lookbook"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 36
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 16
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#E8B4B8"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#C97C8D"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "lookbook_item",
      "name": "Lookbook Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Spring Morning"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Floral hat and cozy sweater for gentle spring days"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook Preview",
      "blocks": [
        {
          "type": "lookbook_item",
          "settings": {
            "title": "Spring Morning",
            "description": "Floral hat and cozy sweater for gentle spring days"
          }
        },
        {
          "type": "lookbook_item",
          "settings": {
            "title": "Storytime Comfort",
            "description": "Cozy reading nook with handmade cushions and blankets"
          }
        },
        {
          "type": "lookbook_item",
          "settings": {
            "title": "Garden Tea Party",
            "description": "Delicate coasters and accessories for afternoon tea"
          }
        }
      ]
    }
  ]
}
{% endschema %}