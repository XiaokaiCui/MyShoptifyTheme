{%- style -%}
  .hero-{{ section.id }} {
    position: relative;
    height: {{ section.settings.height_desktop }}vh;
    min-height: 500px;
    overflow: hidden;
  }
  
  @media screen and (max-width: 768px) {
    .hero-{{ section.id }} {
      height: {{ section.settings.height_mobile }}vh;
      min-height: 400px;
    }
  }
  
  .hero__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  
  .hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.1) 0%,
      rgba(0, 0, 0, 0.2) 100%
    );
    z-index: 2;
  }
  
  .hero__content {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: {{ section.settings.text_alignment }};
    padding: 0 2rem;
    max-width: 1200px;
    margin: 0 auto;
    text-align: {{ section.settings.text_alignment }};
  }
  
  .hero__title {
    font-family: var(--font-heading-family);
    font-size: {{ section.settings.title_size }}px;
    font-weight: var(--font-heading-weight);
    color: {{ section.settings.text_color }};
    margin-bottom: 1.5rem;
    line-height: 1.2;
    max-width: 800px;
  }
  
  .hero__subtitle {
    font-family: var(--font-body-family);
    font-size: {{ section.settings.subtitle_size }}px;
    color: {{ section.settings.text_color }};
    margin-bottom: 2.5rem;
    max-width: 600px;
    line-height: 1.6;
    opacity: 0.9;
  }
  
  .hero__button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background-color: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 500;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }
  
  .hero__button:hover {
    background-color: {{ section.settings.button_hover_color }};
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }
{%- endstyle -%}

<div class="hero hero-{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.image.alt | escape }}"
      class="hero__image"
      loading="lazy"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}"
    >
  {%- else -%}
    <div class="hero__image placeholder-background" style="background: linear-gradient(135deg, #FFE5D4 0%, #E8B4B8 100%);">
      <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: white; font-size: 1.5rem;">
        Handmade Crochet Stories
      </div>
    </div>
  {%- endif -%}
  
  <div class="hero__overlay"></div>
  
  <div class="hero__content">
    {%- if section.settings.title != blank -%}
      <h1 class="hero__title">{{ section.settings.title }}</h1>
    {%- endif -%}
    
    {%- if section.settings.subtitle != blank -%}
      <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    
    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <a href="{{ section.settings.button_link }}" class="hero__button">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Handmade Stories, Stitched with Love"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Unique crocheted clothing, accessories, and home decor inspired by late spring and early summer"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore Collections"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Desktop height",
      "default": 85
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 40,
      "max": 90,
      "step": 5,
      "unit": "vh",
      "label": "Mobile height",
      "default": 75
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 52
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 20
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#E8B4B8"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#C97C8D"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "title": "Handmade Stories, Stitched with Love",
        "subtitle": "Unique crocheted clothing, accessories, and home decor inspired by late spring and early summer",
        "button_label": "Explore Collections"
      }
    }
  ]
}
{% endschema %}