{% comment %}
Contact Page Template
{% endcomment %}

{%- style -%}
  .contact-page {
    padding: 4rem 2rem;
  }
  
  .contact__container {
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .contact__header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .contact__title {
    font-family: var(--font-heading-family);
    font-size: 3rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }
  
  .contact__subtitle {
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    color: {{ settings.color_text_light }};
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .contact__content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }
  
  .contact__info {
    padding: 2rem;
    background-color: {{ settings.color_cream }};
    border-radius: 16px;
  }
  
  .contact__info-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    margin-bottom: 2rem;
  }
  
  .contact__details {
    margin-bottom: 3rem;
  }
  
  .contact__detail {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }
  
  .contact__detail:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }
  
  .contact__detail-icon {
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    background-color: {{ settings.color_dusty_rose }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }
  
  .contact__detail-content {
    flex: 1;
  }
  
  .contact__detail-title {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    color: {{ settings.color_text }};
    margin-bottom: 0.25rem;
  }
  
  .contact__detail-text {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.6;
  }
  
  .contact__detail-link {
    color: {{ settings.color_dusty_rose }};
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .contact__detail-link:hover {
    color: {{ settings.color_dusty_rose | color_darken: 10 }};
    text-decoration: underline;
  }
  
  .contact__hours {
    margin-bottom: 3rem;
  }
  
  .contact__hours-title {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }
  
  .contact__hours-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .contact__hours-item {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }
  
  .contact__hours-item:last-child {
    border-bottom: none;
  }
  
  .contact__hours-day {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text }};
  }
  
  .contact__hours-time {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
  }
  
  .contact__social {
    margin-top: 2rem;
  }
  
  .contact__social-title {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }
  
  .contact__social-links {
    display: flex;
    gap: 1rem;
  }
  
  .contact__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    background-color: white;
    border-radius: 50%;
    color: {{ settings.color_text }};
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }
  
  .contact__social-link:hover {
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    transform: translateY(-2px);
  }
  
  .contact__social-icon {
    width: 24px;
    height: 24px;
  }
  
  .contact__form-container {
    padding: 2rem;
    background-color: white;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }
  
  .contact__form-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    margin-bottom: 2rem;
  }
  
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.5