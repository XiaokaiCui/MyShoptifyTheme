{% comment %}
Story Book Collection Template
{% endcomment %}

{%- style -%}
  .story-book-collection {
    padding: 2rem 2rem 4rem;
  }
  
  .collection__hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    margin-bottom: 4rem;
    border-radius: 16px;
    overflow: hidden;
  }
  
  .collection__hero-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .collection__hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.1) 0%,
      rgba(0, 0, 0, 0.3) 100%
    );
  }
  
  .collection__hero-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    text-align: center;
    color: white;
  }
  
  .collection__title {
    font-family: var(--font-heading-family);
    font-size: 3.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  
  .collection__description {
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
    opacity: 0.9;
  }
  
  .collection__intro {
    max-width: 800px;
    margin: 0 auto 4rem;
    text-align: center;
  }
  
  .collection__intro-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
  }
  
  .collection__intro-content {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.8;
  }
  
  .collection__intro-content p {
    margin-bottom: 1.5rem;
  }
  
  .collection__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }
  
  .collection__product {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background-color: white;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .collection__product:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }
  
  .collection__product-image-container {
    position: relative;
    height: 300px;
    overflow: hidden;
  }
  
  .collection__product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .collection__product:hover .collection__product-image {
    transform: scale(1.05);
  }
  
  .collection__product-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 0.8rem;
    font-weight: 500;
    z-index: 2;
  }
  
  .collection__product-content {
    padding: 1.5rem;
  }
  
  .collection__product-title {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    color: {{ settings.color_text }};
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  
  .collection__product-price {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text }};
    font-weight: 600;
    margin-bottom: 1rem;
    opacity: 0.9;
  }
  
  .collection__product-description {
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    color: {{ settings.color_text_light }};
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }
  
  .collection__product-button {
    display: inline-block;
    width: 100%;
    padding: 0.75rem;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    font-weight: 500;
    text-align: center;
    transition: background-color 0.3s ease;
  }
  
  .collection__product-button:hover {
    background-color: {{ settings.color_dusty_rose | color_darken: 10 }};
  }
  
  .collection__story {
    background-color: {{ settings.color_cream }};
    padding: 4rem 2rem;
    border-radius: 16px;
    margin-bottom: 4rem;
  }
  
  .collection__story-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .collection__story-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .collection__story-item {
    text-align: center;
    padding: 2rem;
    background-color: white;
    border-radius: 12px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
  }
  
  .collection__story-icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ settings.color_dusty_rose }};
    border-radius: 50%;
    color: white;
    font-size: 1.5rem;
  }
  
  .collection__story-item-title {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }
  
  .collection__story-item-content {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.6;
  }
  
  .collection__empty {
    text-align: center;
    padding: 4rem 2rem;
    background-color: {{ settings.color_cream }};
    border-radius: 16px;
  }
  
  .collection__empty-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
  }
  
  .collection__empty-text {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text_light }};
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }
  
  .collection__empty-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    text-decoration: none;
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }
  
  .collection__empty-button:hover {
    background-color: {{ settings.color_dusty_rose | color_darken: 10 }};
    transform: translateY(-2px);
  }
  
  @media screen and (max-width: 768px) {
    .story-book-collection {
      padding: 1rem 1rem 3rem;
    }
    
    .collection__hero {
      height: 50vh;
      min-height: 300px;
      margin-bottom: 3rem;
    }
    
    .collection__title {
      font-size: 2.5rem;
    }
    
    .collection__description {
      font-size: 1.1rem;
    }
    
    .collection__grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
    }
    
    .collection__product-image-container {
      height: 250px;
    }
    
    .collection__story {
      padding: 3rem 1rem;
    }
  }
{%- endstyle -%}

<div class="story-book-collection">
  <div class="collection__hero">
    {%- if section.settings.hero_image != blank -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 2000 }}"
        alt="{{ collection.title | escape }}"
        class="collection__hero-image"
        loading="lazy"
        width="2000"
        height="800"
      >
    {%- else -%}
      <div class="collection__hero-image" style="background: linear-gradient(135deg, {{ settings.color_peach }} 0%, {{ settings.color_dusty_rose }} 100%);"></div>
    {%- endif -%}
    
    <div class="collection__hero-overlay"></div>
    
    <div class="collection__hero-content">
      <h1 class="collection__title">{{ collection.title | default: 'Story Book Collection' }}</h1>
      <p class="collection__description">{{ section.settings.hero_description | default: 'Step into a world where every stitch tells a tale. Inspired by beloved characters, magical moments, and timeless narratives.' }}</p>
    </div>
  </div>
  
  <div class="collection__intro">
    <h2 class="collection__intro-title">{{ section.settings.intro_title | default: 'Welcome to Our Storybook' }}</h2>
    <div class="collection__intro-content">
      {{ section.settings.intro_content | default: '<p>Each piece in this collection is inspired by stories that have touched our hearts—classic tales, beloved characters, and magical moments that feel like coming home.</p><p>From cozy sweaters that feel like a warm hug to accessories that add a touch of whimsy to your day, every item is a chapter waiting to be lived. We believe that the clothes we wear can tell stories too, becoming part of our own personal narratives.</p>' }}
    </div>
  </div>
  
  {%- if collection.products_count > 0 -%}
    <div class="collection__grid">
      {%- for product in collection.products -%}
        <div class="collection__product">
          <div class="collection__product-image-container">
            {%- if product.featured_image != blank -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.title | escape }}"
                class="collection__product-image"
                loading="lazy"
                width="600"
                height="400"
              >
            {%- else -%}
              <div class="collection__product-image" style="background: linear-gradient(135deg, {{ settings.color_cream }} 0%, {{ settings.color_sage }} 100%); height: 100%; display: flex; align-items: center; justify-content: center; color: {{ settings.color_text }}; font-size: 1rem;">
                {{ product.title }}
              </div>
            {%- endif -%}
            
            {%- if product.tags contains 'bestseller' -%}
              <div class="collection__product-badge">Bestseller</div>
            {%- elsif product.tags contains 'new' -%}
              <div class="collection__product-badge">New</div>
            {%- endif -%}
          </div>
          
          <div class="collection__product-content">
            <h3 class="collection__product-title">{{ product.title }}</h3>
            <div class="collection__product-price">{{ product.price | money }}</div>
            {%- if product.description != blank -%}
              <p class="collection__product-description">{{ product.description | strip_html | truncate: 100 }}</p>
            {%- endif -%}
            <a href="{{ product.url }}" class="collection__product-button">View Product</a>
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="collection__empty">
      <h2 class="collection__empty-title">Coming Soon</h2>
      <p class="collection__empty-text">Our Story Book Collection is being carefully crafted. New pieces will be added soon with stories to tell.</p>
      <a href="/collections/all" class="collection__empty-button">Browse All Collections</a>
    </div>
  {%- endif -%}
  
  <div class="collection__story">
    <h2 class="collection__story-title">{{ section.settings.story_title | default: 'The Stories Behind the Stitches' }}</h2>
    <div class="collection__story-grid">
      <div class="collection__story-item">
        <div class="collection__story-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <h3 class="collection__story-item-title">Classic Tales</h3>
        <p class="collection__story-item-content">Inspired by stories that have been loved for generations, bringing timeless magic to modern wear.</p>
      </div>
      
      <div class="collection__story-item">
        <div class="collection__story-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a10 10 0 1 0 10 10H12V2z"/>
            <path d="M12 12a10 10 0 0 0 10 10"/>
          </svg>
        </div>
        <h3 class="collection__story-item-title">Magical Moments</h3>
        <p class="collection__story-item-content">Capturing the feeling of wonder and possibility that comes with turning a page.</p>
      </div>
      
      <div class="collection__story-item">
        <div class="collection__story-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>
        <h3 class="collection__story-item-title">Beloved Characters</h3>
        <p class="collection__story-item-content">Whimsical designs that celebrate the characters who feel like old friends.</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Story Book Collection",
  "tag": "section",
  "class": "section-collection",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Hero description",
      "default": "Step into a world where every stitch tells a tale. Inspired by beloved characters, magical moments, and timeless narratives."
    },
    {
      "type": "text",
      "id": "intro