{% comment %}
About Page Template
{% endcomment %}

{%- style -%}
  .about-page {
    padding: 4rem 2rem;
  }
  
  .about__container {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .about__header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .about__title {
    font-family: var(--font-heading-family);
    font-size: 3rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }
  
  .about__subtitle {
    font-family: var(--font-body-family);
    font-size: 1.2rem;
    color: {{ settings.color_text_light }};
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .about__content {
    display: grid;
    gap: 4rem;
  }
  
  .about__section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  
  .about__section--reverse .about__image {
    order: 2;
  }
  
  .about__section--reverse .about__text {
    order: 1;
  }
  
  .about__image-container {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }
  
  .about__image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s ease;
  }
  
  .about__image-container:hover .about__image {
    transform: scale(1.05);
  }
  
  .about__text {
    padding: 1rem;
  }
  
  .about__section-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }
  
  .about__section-content {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.8;
  }
  
  .about__section-content p {
    margin-bottom: 1.5rem;
  }
  
  .about__section-content p:last-child {
    margin-bottom: 0;
  }
  
  .about__values {
    background-color: {{ settings.color_cream }};
    padding: 4rem 2rem;
    border-radius: 16px;
    margin-top: 4rem;
  }
  
  .about__values-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .about__values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .about__value {
    text-align: center;
    padding: 2rem;
    background-color: white;
    border-radius: 12px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
  }
  
  .about__value-icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ settings.color_dusty_rose }};
    border-radius: 50%;
    color: white;
    font-size: 1.5rem;
  }
  
  .about__value-title {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }
  
  .about__value-description {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.6;
  }
  
  .about__cta {
    text-align: center;
    margin-top: 4rem;
    padding: 4rem;
    background-color: {{ settings.color_peach }};
    border-radius: 16px;
  }
  
  .about__cta-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
  }
  
  .about__cta-text {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text_light }};
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }
  
  .about__cta-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    text-decoration: none;
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }
  
  .about__cta-button:hover {
    background-color: {{ settings.color_dusty_rose | color_darken: 10 }};
    transform: translateY(-2px);
  }
  
  @media screen and (max-width: 768px) {
    .about-page {
      padding: 2rem 1rem;
    }
    
    .about__title {
      font-size: 2.5rem;
    }
    
    .about__section {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .about__section--reverse .about__image {
      order: 1;
    }
    
    .about__section--reverse .about__text {
      order: 2;
    }
    
    .about__values {
      padding: 3rem 1rem;
    }
    
    .about__cta {
      padding: 3rem 1.5rem;
    }
  }
{%- endstyle -%}

<div class="about-page">
  <div class="about__container">
    <div class="about__header">
      <h1 class="about__title">{{ page.title }}</h1>
      {%- if page.content != blank -%}
        <div class="about__subtitle">{{ page.content }}</div>
      {%- endif -%}
    </div>
    
    <div class="about__content">
      <div class="about__section">
        <div class="about__image-container">
          {%- if section.settings.image_1 != blank -%}
            <img
              src="{{ section.settings.image_1 | image_url: width: 800 }}"
              alt="{{ section.settings.image_1.alt | escape }}"
              class="about__image"
              loading="lazy"
              width="800"
              height="600"
            >
          {%- else -%}
            <div class="about__image" style="background: linear-gradient(135deg, {{ settings.color_peach }} 0%, {{ settings.color_dusty_rose }} 100%); height: 400px; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.2rem;">
              Our Story Begins Here
            </div>
          {%- endif -%}
        </div>
        
        <div class="about__text">
          <h2 class="about__section-title">{{ section.settings.title_1 | default: 'Our Beginning' }}</h2>
          <div class="about__section-content">
            {{ section.settings.content_1 | default: '<p>Every piece begins with a story—a quiet moment, a memory, a feeling we want to capture. What started as a personal passion for crochet has grown into a community of makers and dreamers.</p><p>Founded in a small studio filled with natural light and baskets of colorful yarn, our journey is one of slow, intentional creation. We believe that the things we surround ourselves with should carry meaning and beauty.</p>' }}
          </div>
        </div>
      </div>
      
      <div class="about__section about__section--reverse">
        <div class="about__image-container">
          {%- if section.settings.image_2 != blank -%}
            <img
              src="{{ section.settings.image_2 | image_url: width: 800 }}"
              alt="{{ section.settings.image_2.alt | escape }}"
              class="about__image"
              loading="lazy"
              width="800"
              height="600"
            >
          {%- else -%}
            <div class="about__image" style="background: linear-gradient(135deg, {{ settings.color_sage }} 0%, {{ settings.color_beige }} 100%); height: 400px; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.2rem;">
              The Making Process
            </div>
          {%- endif -%}
        </div>
        
        <div class="about__text">
          <h2 class="about__section-title">{{ section.settings.title_2 | default: 'The Making Process' }}</h2>
          <div class="about__section-content">
            {{ section.settings.content_2 | default: '<p>Each piece is carefully crafted by hand, using natural fibers and traditional techniques passed down through generations. We work slowly, paying attention to every stitch, every detail.</p><p>Our process is a meditation—a way to connect with materials, with tradition, and with the stories we want to tell. From selecting the perfect yarn to adding the final touches, every step is done with care and intention.</p><p>We draw inspiration from the gentle transition between seasons—the soft light of late spring, the first warmth of early summer, the quiet beauty of nature awakening.</p>' }}
          </div>
        </div>
      </div>
    </div>
    
    <div class="about__values">
      <h2 class="about__values-title">{{ section.settings.values_title | default: 'Our Values' }}</h2>
      <div class="about__values-grid">
        <div class="about__value">
          <div class="about__value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
              <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
            </svg>
          </div>
          <h3 class="about__value-title">Sustainability</h3>
          <p class="about__value-description">We source eco-friendly materials and minimize waste in every step of our process.</p>
        </div>
        
        <div class="about__value">
          <div class="about__value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
            </svg>
          </div>
          <h3 class="about__value-title">Made with Love</h3>
          <p class="about__value-description">Every stitch is placed with intention and care, creating pieces that carry emotion.</p>
        </div>
        
        <div class="about__value">
          <div class="about__value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </div>
          <h3 class="about__value-title">Quality Craftsmanship</h3>
          <p class="about__value-description">Traditional techniques and attention to detail ensure each piece is made to last.</p>
        </div>
        
        <div class="about__value">
          <div class="about__value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="about__value-title">Supporting Artisans</h3>
          <p class="about__value-description">We believe in fair compensation and supporting the handmade community.</p>
        </div>
      </div>
    </div>
    
    <div class="about__cta">
      <h2 class="about__cta-title">{{ section.settings.cta_title | default: 'Join Our Story' }}</h2>
      <p class="about__cta-text">{{ section.settings.cta_text | default: 'Whether you&apos;re looking for a special piece or want to learn more about our process, we&apos;d love to connect with you.' }}</p>
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="about__cta-button">
        {{ section.settings.cta_button | default: 'Explore Our Collections' }}
      </a>
    </div>
  </div>
</div>

{% schema %}
