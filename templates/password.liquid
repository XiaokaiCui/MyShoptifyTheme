{% comment %}
Password Page - For password-protected stores
URL: Shown when store is password protected
{% endcomment %}

{%- style -%}
  .password-page {
    padding: 4rem 2rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, {{ settings.color_cream }} 0%, {{ settings.color_peach }} 100%);
  }
  
  .password__container {
    max-width: 500px;
    width: 100%;
    background-color: white;
    border-radius: 24px;
    padding: 3rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
    text-align: center;
  }
  
  .password__logo {
    margin-bottom: 2rem;
  }
  
  .password__logo-image {
    max-width: 150px;
    height: auto;
    margin: 0 auto;
  }
  
  .password__logo-text {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    margin: 0;
  }
  
  .password__title {
    font-family: var(--font-heading-family);
    font-size: 2.5rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  
  .password__subtitle {
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    color: {{ settings.color_text_light }};
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  
  .password__message {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text_light }};
    margin-bottom: 3rem;
    line-height: 1.6;
  }
  
  .password__form {
    margin-bottom: 2rem;
  }
  
  .password__form-group {
    margin-bottom: 1.5rem;
  }
  
  .password__input {
    width: 100%;
    padding: 1rem 1.5rem;
    border: 2px solid {{ settings.color_border }};
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text }};
    transition: border-color 0.3s ease;
  }
  
  .password__input:focus {
    outline: none;
    border-color: {{ settings.color_dusty_rose }};
  }
  
  .password__button {
    width: 100%;
    padding: 1rem;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    border: none;
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .password__button:hover {
    background-color: {{ settings.color_dusty_rose | color_darken: 10 }};
    transform: translateY(-2px);
  }
  
  .password__error {
    background-color: #fee;
    border: 1px solid #f99;
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    color: #c00;
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    display: none;
  }
  
  .password__error.show {
    display: block;
  }
  
  .password__success {
    background-color: #dfd;
    border: 1px solid #9d9;
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    color: #090;
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    display: none;
  }
  
  .password__success.show {
    display: block;
  }
  
  .password__newsletter {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid {{ settings.color_border }};
  }
  
  .password__newsletter-title {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }
  
  .password__newsletter-text {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }
  
  .password__newsletter-form {
    display: flex;
    gap: 0.5rem;
  }
  
  .password__newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid {{ settings.color_border }};
    border-radius: 8px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text }};
    transition: border-color 0.3s ease;
  }
  
  .password__newsletter-input:focus {
    outline: none;
    border-color: {{ settings.color_dusty_rose }};
  }
  
  .password__newsletter-button {
    padding: 0.75rem 1.5rem;
    background-color: {{ settings.color_sage }};
    color: white;
    border: none;
    border-radius: 8px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }
  
  .password__newsletter-button:hover {
    background-color: {{ settings.color_sage | color_darken: 10 }};
  }
  
  .password__social {
    margin-top: 2rem;
  }
  
  .password__social-title {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
    margin-bottom: 1rem;
  }
  
  .password__social-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
  
  .password__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: {{ settings.color_cream }};
    border-radius: 50%;
    color: {{ settings.color_text }};
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .password__social-link:hover {
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    transform: translateY(-2px);
  }
  
  .password__footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid {{ settings.color_border }};
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    color: {{ settings.color_text_light }};
  }
  
  .password__admin-link {
    color: {{ settings.color_dusty_rose }};
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .password__admin-link:hover {
    color: {{ settings.color_text }};
    text-decoration: underline;
  }
  
  @media screen and (max-width: 768px) {
    .password-page {
      padding: 2rem 1rem;
    }
    
    .password__container {
      padding: 2rem 1.5rem;
    }
    
    .password__title {
      font-size: 2rem;
    }
    
    .password__subtitle {
      font-size: 1.1rem;
    }
    
    .password__newsletter-form {
      flex-direction: column;
    }
    
    .password__newsletter-button {
      width: 100%;
    }
  }
{%- endstyle -%}

<div class="password-page">
  <div class="password__container">
    <div class="password__logo">
      {% if settings.logo %}
        <img
          src="{{ settings.logo | image_url: width: 300 }}"
          alt="{{ shop.name }}"
          class="password__logo-image"
          loading="lazy"
          width="300"
          height="100"
        >
      {% else %}
        <h1 class="password__logo-text">{{ shop.name }}</h1>
      {% endif %}
    </div>
    
    <h2 class="password__title">{{ 'password_page.title' | t }}</h2>
    
    <p class="password__subtitle">{{ 'password_page.subtitle' | t }}</p>
    
    <p class="password__message">
      {{ 'password_page.message' | default: 'Our handmade collection is coming soon. Enter the password to preview our store.' }}
    </p>
    
    <div class="password__error" id="PasswordError">
      {{ 'password_page.incorrect_password' | t }}
    </div>
    
    <div class="password__success" id="PasswordSuccess">
      {{ 'password_page.correct_password' | t }}
    </div>
    
    {% form 'storefront_password', class: 'password__form' %}
      <div class="password__form-group">
        <input
          type="password"
          name="password"
          id="Password"
          class="password__input"
          placeholder="{{ 'password_page.placeholder' | t }}"
          aria-label="{{ 'password_page.placeholder' | t }}"
          required
        >
      </div>
      
      <button type="submit" name="commit" class="password__button">
        {{ 'password_page.submit' | t }}
      </button>
    {% endform %}
    
    <div class="password__newsletter">
      <h3 class="password__newsletter-title">{{ 'password_page.newsletter_title' | t }}</h3>
      <p class="password__newsletter-text">
        {{ 'password_page.newsletter_text' | default: 'Be the first to know when we launch. Sign up for updates and exclusive early access.' }}
      </p>
      
      {% form 'customer', class: 'password__newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          id="NewsletterEmail"
          class="password__newsletter-input"
          placeholder="{{ 'password_page.email_placeholder' | t }}"
          aria-label="{{ 'password_page.email_placeholder' | t }}"
          required
        >
        <button type="submit" class="password__newsletter-button">
          {{ 'password_page.newsletter_submit' | t }}
        </button>
      {% endform %}
    </div>
    
    <div class="password__social">
      <p class="password__social-title">{{ 'password_page.follow_us' | t }}</p>
      <div class="password__social-links">
        <a href="https://instagram.com" class="password__social-link" target="_blank" rel="noopener" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="https://pinterest.com" class="password__social-link" target="_blank" rel="noopener" aria-label="Pinterest">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path>
            <path d="M12 8c-2.21 0-4 1.79-4 4 0 1.1.45 2.1 1.17 2.83.05.06.1.13.14.19.23.43.35.92.35 1.43 0 .28-.22.5-.5.5h-1.5c-.28 0-.5-.22-.5-.5v-1.5c0-.28.22-.5.5-.5h.5c.28 0 .5-.22.5-.5v-2c0-1.1-.9-2-2-2s-2 .9-2 2v4c0 1.1.9 2 2 2h1c1.1 0 2-.9 2-2v-1c0-1.1-.9-2-2-2s-2 .9-2 2v1c0 .28.22.5.5.5h1c.28 0 .5-.22.5-.5v-2c0-1.1.9-2 2-2s2 .9 2 2v4c0 1.1.9 2 2 2h1c1.1 0 2-.9 2-2v-4c0-2.21-1.79-4-4-4z"></path>
          </svg>
        </a>
        <a href="https://etsy.com" class="password__social-link" target="_blank" rel="noopener" aria-label="Etsy">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path>
            <path d="M8 16l4-4 4 4"></path>
            <path d="M12 12v8"></path>
          </svg>
        </a>
      </div>
    </div>
    
    <div class="password__footer">
      <p>
        {{ 'password_page.admin' | t }}
        <a href="/admin" class="password__admin-link">
          {{ 'password_page.admin_link' | t }}
        </a>
      </p>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Password form handling
  const passwordForm = document.querySelector('form[action*="/password"]');
  const passwordInput = document.getElementById('Password');
  const passwordError = document.getElementById('PasswordError');
  const passwordSuccess = document.getElementById('PasswordSuccess');
  
  if (passwordForm) {
    passwordForm.addEventListener('submit', function(e) {
      // This would normally be handled by Shopify
      // This is just for UI feedback
      e.preventDefault();
      
      const password = passwordInput.value;
      
      // Simple validation (in reality, Shopify handles this)
      if (password.length < 1) {
        passwordError.textContent = 'Please enter a password';
        passwordError.classList.add('show');
        passwordSuccess.classList.remove('show');
        return;
      }
      
      // Show success message
      passwordError.classList.remove('show');
      passwordSuccess.classList.add('show');
      
      // In reality, Shopify would redirect if password is correct
      // For demo purposes, we'll simulate a redirect
      setTimeout(() => {
        // This would be the actual redirect in production
        // window.location.href = '/';
        
        // For demo, just show a message
        passwordSuccess.textContent = 'Password accepted! Redirecting...';
      }, 1000);
    });
  }
  
  // Newsletter form
  const newsletterForm = document.querySelector('form[action*="/contact"]');
  const newsletterEmail = document.getElementById('NewsletterEmail');
  
  if (newsletterForm) {
    newsletterForm.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const email = newsletterEmail.value;
      
      if (!email || !email.includes('@')) {
        alert('Please enter a valid email address');
        return;
      }
      
      // Show success message
      const successMessage = document.createElement('div');
      successMessage.className = 'password__success show';
      successMessage.textContent = 'Thank you for subscribing!';
      successMessage.style.marginTop = '1rem';
      
      newsletterForm.parentNode.insertBefore(successMessage, newsletterForm.nextSibling);
      
      // Reset form
      newsletterEmail.value = '';
      
      // Remove message after 5 seconds
      setTimeout(() => {
        successMessage.remove();
      }, 5000);
    });
  }
  
  // Add some visual interest
  const container = document.querySelector('.password__container');
  if (container) {
    container.style.transition = 'transform 0.5s ease, opacity 0.5s ease';
    container.style.opacity = '0';
    container.style.transform = 'translateY(20px)';
    
    setTimeout(() => {
      container.style.opacity = '1';
      container.style.transform = 'translateY(0)';
    }, 100);
  }
  
  // Focus password input
  if (passwordInput) {
    setTimeout(() => {
      passwordInput.focus();
    }, 500);
  }
});

// Add CSS for animations
const style = document.createElement('style');
style.textContent = `
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .password__container {
    animation: fadeInUp 0.6s ease;
  }
`;
document.head.appendChild(style);
