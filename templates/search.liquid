{% comment %}
Search Results Page
URL: /search?q=[query]
{% endcomment %}

{%- style -%}
  .search-page {
    padding: 4rem 2rem;
    min-height: 60vh;
  }
  
  .search__container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .search__header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .search__title {
    font-family: var(--font-heading-family);
    font-size: 3rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }
  
  .search__subtitle {
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    color: {{ settings.color_text_light }};
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .search__form {
    max-width: 600px;
    margin: 0 auto 3rem;
    position: relative;
  }
  
  .search__input {
    width: 100%;
    padding: 1rem 1.5rem;
    padding-right: 60px;
    border: 2px solid {{ settings.color_border }};
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text }};
    transition: border-color 0.3s ease;
  }
  
  .search__input:focus {
    outline: none;
    border-color: {{ settings.color_dusty_rose }};
  }
  
  .search__button {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    padding: 0 1.5rem;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    border: none;
    border-radius: 0 50px 50px 0;
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }
  
  .search__button:hover {
    background-color: {{ settings.color_dusty_rose | color_darken: 10 }};
  }
  
  .search__results {
    margin-bottom: 4rem;
  }
  
  .search__results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid {{ settings.color_border }};
  }
  
  .search__results-title {
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    color: {{ settings.color_text }};
  }
  
  .search__results-count {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
  }
  
  .search__results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }
  
  .search__result {
    background-color: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease;
  }
  
  .search__result:hover {
    transform: translateY(-5px);
  }
  
  .search__result-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  
  .search__result-content {
    padding: 1.5rem;
  }
  
  .search__result-type {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background-color: {{ settings.color_cream }};
    color: {{ settings.color_text_light }};
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 0.8rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }
  
  .search__result-type--product {
    background-color: {{ settings.color_dusty_rose }};
    color: white;
  }
  
  .search__result-type--page {
    background-color: {{ settings.color_sage }};
    color: white;
  }
  
  .search__result-type--article {
    background-color: {{ settings.color_beige }};
    color: white;
  }
  
  .search__result-title {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    color: {{ settings.color_text }};
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  
  .search__result-link {
    color: {{ settings.color_text }};
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .search__result-link:hover {
    color: {{ settings.color_dusty_rose }};
  }
  
  .search__result-excerpt {
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    color: {{ settings.color_text_light }};
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  
  .search__result-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
  }
  
  .search__result-price {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text }};
    font-weight: 600;
  }
  
  .search__result-button {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }
  
  .search__result-button:hover {
    background-color: {{ settings.color_dusty_rose | color_darken: 10 }};
  }
  
  .search__empty {
    text-align: center;
    padding: 4rem 2rem;
    background-color: {{ settings.color_cream }};
    border-radius: 16px;
    margin-bottom: 4rem;
  }
  
  .search__empty-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 2rem;
    color: {{ settings.color_text_light }};
  }
  
  .search__empty-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
  }
  
  .search__empty-text {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text_light }};
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }
  
  .search__empty-suggestions {
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
  }
  
  .search__empty-suggestions-title {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }
  
  .search__empty-suggestions-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .search__empty-suggestion {
    margin-bottom: 0.5rem;
  }
  
  .search__empty-suggestion-link {
    color: {{ settings.color_dusty_rose }};
    text-decoration: none;
    font-family: var(--font-body-family);
    font-size: 1rem;
    transition: color 0.3s ease;
  }
  
  .search__empty-suggestion-link:hover {
    color: {{ settings.color_text }};
    text-decoration: underline;
  }
  
  .search__filters {
    background-color: {{ settings.color_cream }};
    padding: 2rem;
    border-radius: 16px;
    margin-bottom: 3rem;
  }
  
  .search__filters-title {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
  }
  
  .search__filters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  
  .search__filter {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .search__filter-label {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text }};
    font-weight: 500;
  }
  
  .search__filter-select {
    padding: 0.75rem 1rem;
    border: 1px solid {{ settings.color_border }};
    border-radius: 8px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text }};
    background-color: white;
    cursor: pointer;
    transition: border-color 0.3s ease;
  }
  
  .search__filter-select:focus {
    outline: none;
    border-color: {{ settings.color_dusty_rose }};
  }
  
  .search__pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
  }
  
  .search__pagination-button {
    padding: 0.75rem 1.5rem;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    border: none;
    border-radius: 8px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
  }
  
  .search__pagination-button:hover:not(:disabled) {
    background-color: {{ settings.color_dusty_rose | color_darken: 10 }};
    transform: translateY(-2px);
  }
  
  .search__pagination-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  .search__pagination-info {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
  }
  
  @media screen and (max-width: 768px) {
    .search-page {
      padding: 2rem 1rem;
    }
    
    .search__title {
      font-size: 2.5rem;
    }
    
    .search__results-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
    }
    
    .search__filters {
      padding: 1.5rem;
    }
    
    .search__filters-grid {
      grid-template-columns: 1fr;
    }
    
    .search__pagination {
      flex-wrap: wrap;
    }
  }
{%- endstyle -%}

<div class="search-page">
  <div class="search__container">
    <div class="search__header">
      <h1 class="search__title">
        {% if search.performed %}
          {{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
        {% else %}
          {{ 'general.search.title' | t }}
        {% endif %}
      </h1>
      
      <p class="search__subtitle">
        {% if search.performed %}
          {{ 'general.search.results_for' | t: terms: search.terms }}
        {% else %}
          {{ 'general.search.placeholder' | t }}
        {% endif %}
      </p>
    </div>
    
    <form action="{{ routes.search_url }}" method="get" role="search" class="search__form">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.placeholder' | t }}"
        class="search__input"
        aria-label="{{ 'general.search.placeholder' | t }}"
      >
      <button type="submit" class="search__button">
        {{ 'general.search.search' | t }}
      </button>
    </form>
    
    {% if search.performed %}
      {% if search.results_count > 0 %}
        <div class="search__filters">
          <h2 class="search__filters-title">{{ 'general.search.filter_by' | t }}</h2>
          <div class="search__filters-grid">
            <div class="search__filter">
              <label for="search-type" class="search__filter-label">{{ 'general.search.type' | t }}</label>
              <select id="search-type" class="search__filter-select">
                <option value="all">{{ 'general.search.all_types' | t }}</option>
                <option value="product">{{ 'general.search.products' | t }}</option>
                <option value="page">{{ 'general.search.pages' | t }}</option>
                <option value="article">{{ 'general.search.articles' | t }}</option>
              </select>
            </div>
            
            <div class="search__filter">
              <label for="search-sort" class="search__filter-label">{{ 'general.search.sort_by' | t }}</label>
              <select id="search-sort" class="search__filter-select">
                <option value="relevance">{{ 'general.search.relevance' | t }}</option>
                <option value="price-ascending">{{ 'general.search.price_low_to_high' | t }}</option>
                <option value="price-descending">{{ 'general.search.price_high_to_low' | t }}</option>
                <option value="newest">{{ 'general.search.newest' | t }}</option>
              </select>
            </div>
          </div>
        </div>
        
        <div class="search__results">
          <div class="search__results-header">
            <h2 class="search__results-title">{{ 'general.search.results' | t }}</h2>
            <span class="search__results-count">{{ search.results_count }} {{ 'general.search.results_count' | t: count: search.results_count }}</span>
          </div>
          
          <div class="search__results-grid">
            {% for item in search.results %}
              <div class="search__result" data-type="{{ item.object_type }}">
                {% if item.object_type == 'product' %}
                  <span class="search__result-type search__result-type--product">{{ 'general.search.product' | t }}</span>
                  
                  {% if item.featured_image %}
                    <img
                      src="{{ item.featured_image | image_url: width: 400 }}"
                      alt="{{ item.featured_image.alt | escape }}"
                      class="search__result-image"
                      loading="lazy"
                      width="400"
                      height="200"
                    >
                  {% else %}
                    <div class="search__result-image" style="background: linear-gradient(135deg, {{ settings.color_cream }} 0%, {{ settings.color_peach }} 100%);"></div>
                  {% endif %}
                  
                  <div class="search__result-content">
                    <h3 class="search__result-title">
                      <a href="{{ item.url }}" class="search__result-link">{{ item.title }}</a>
                    </h3>
                    
                    <p class="search__result-excerpt">
                      {{ item.content | strip_html | truncatewords: 20 }}
                    </p>
                    
                    <div class="search__result-meta">
                      <span class="search__result-price">{{ item.price | money }}</span>
                      <a href="{{ item.url }}" class="search__result-button">
                        {{ 'general.search.view_product' | t }}
                      </a>
                    </div>
                  </div>
                  
                {% elsif item.object_type == 'page' %}
                  <span class="search__result-type search__result-type--page">{{ 'general.search.page' | t }}</span>
                  
                  <div class="search__result-content">
                    <h3 class="search__result-title">
                      <a href="{{ item.url }}" class="search__result-link">{{ item.title }}</a>
                    </h3>
                    
                    <p class="search__result-excerpt">
                      {{ item.content | strip_html | truncatewords: 30 }}
                    </p>
                    
                    <div class="search__result-meta">
                      <a href="{{ item.url }}" class="search__result-button">
                        {{ 'general.search.view_page' | t }}
                      </a>
                    </div>
                  </div>
                  
                {% elsif item.object_type == 'article' %}
                  <span class="search__result-type search__result-type--article">{{ 'general.search.article' | t }}</span>
                  
                  {% if item.image %}
                    <img
                      src="{{ item.image | image_url: width: 400 }}"
                      alt="{{ item.image.alt | escape }}"
                      class="search__result-image"
                      loading="lazy"
                      width="400"
                      height="200"
                    >
                  {% else %}
                    <div class="search__result-image" style="background: linear-gradient(135deg, {{ settings.color_cream }} 0%, {{ settings.color_peach }} 100%);"></div>
                  {% endif %}
                  
                  <div class="search__result-content">
                    <
                    <h3 class="search__result-title">
                      <a href="{{ item.url }}" class="search__result-link">{{ item.title }}</a>
                    </h3>
                    
                    <p class="search__result-excerpt">
                      {{ item.excerpt_or_content | strip_html | truncatewords: 25 }}
                    </p>
                    
                    <div class="search__result-meta">
                      <span class="search__result-date">{{ item.published_at | date: "%B %d, %Y" }}</span>
                      <a href="{{ item.url }}" class="search__result-button">
                        {{ 'general.search.read_article' | t }}
                      </a>
                    </div>
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
          
          {% if paginate.pages > 1 %}
            <div class="search__pagination">
              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}" class="search__pagination-button">
                  {{ 'general.search.previous' | t }}
                </a>
              {% else %}
                <button class="search__pagination-button" disabled>
                  {{ 'general.search.previous' | t }}
                </button>
              {% endif %}
              
              <span class="search__pagination-info">
                {{ 'general.search.page' | t: current: paginate.current_page, total: paginate.pages }}
              </span>
              
              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" class="search__pagination-button">
                  {{ 'general.search.next' | t }}
                </a>
              {% else %}
                <button class="search__pagination-button" disabled>
                  {{ 'general.search.next' | t }}
                </button>
              {% endif %}
            </div>
          {% endif %}
        </div>
        
      {% else %}
        <div class="search__empty">
          <svg class="search__empty-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            <line x1="11" y1="8" x2="11" y2="14"></line>
            <line x1="8" y1="11" x2="14" y2="11"></line>
          </svg>
          
          <h2 class="search__empty-title">{{ 'general.search.no_results' | t: terms: search.terms }}</h2>
          
          <p class="search__empty-text">
            {{ 'general.search.no_results_message' | t }}
          </p>
          
          <div class="search__empty-suggestions">
            <h3 class="search__empty-suggestions-title">{{ 'general.search.suggestions' | t }}</h3>
            <ul class="search__empty-suggestions-list">
              <li class="search__empty-suggestion">
                <a href="/collections/all" class="search__empty-suggestion-link">
                  {{ 'general.search.browse_all_products' | t }}
                </a>
              </li>
              <li class="search__empty-suggestion">
                <a href="/collections" class="search__empty-suggestion-link">
                  {{ 'general.search.browse_collections' | t }}
                </a>
              </li>
              <li class="search__empty-suggestion">
                <a href="/pages/catalog" class="search__empty-suggestion-link">
                  {{ 'general.search.view_catalog' | t }}
                </a>
              </li>
            </ul>
          </div>
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Filter functionality
  const typeFilter = document.getElementById('search-type');
  const sortFilter = document.getElementById('search-sort');
  const searchResults = document.querySelectorAll('.search__result');
  
  function filterResults() {
    const selectedType = typeFilter.value;
    const selectedSort = sortFilter.value;
    
    // Filter by type
    searchResults.forEach(result => {
      const resultType = result.getAttribute('data-type');
      
      if (selectedType === 'all' || resultType === selectedType) {
        result.style.display = 'block';
      } else {
        result.style.display = 'none';
      }
    });
    
    // Note: Sorting would require server-side implementation
    // This is just a UI demonstration
  }
  
  if (typeFilter) {
    typeFilter.addEventListener('change', filterResults);
  }
  
  if (sortFilter) {
    sortFilter.addEventListener('change', filterResults);
  }
  
  // Search form enhancement
  const searchForm = document.querySelector('.search__form');
  const searchInput = searchForm.querySelector('input[name="q"]');
  
  if (searchInput && searchInput.value) {
    // Highlight search terms in results
    const searchTerms = searchInput.value.toLowerCase().split(' ');
    const resultTitles = document.querySelectorAll('.search__result-title');
    const resultExcerpts = document.querySelectorAll('.search__result-excerpt');
    
    function highlightText(element) {
      let text = element.textContent;
      searchTerms.forEach(term => {
        if (term.length > 2) {
          const regex = new RegExp(`(${term})`, 'gi');
          text = text.replace(regex, '<mark>$1</mark>');
        }
      });
      element.innerHTML = text;
    }
    
    resultTitles.forEach(highlightText);
    resultExcerpts.forEach(highlightText);
  }
});
</script>
