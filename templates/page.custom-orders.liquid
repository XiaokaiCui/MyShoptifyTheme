{% comment %}
Custom Orders Page Template
{% endcomment %}

{%- style -%}
  .custom-orders-page {
    padding: 4rem 2rem;
  }
  
  .custom-orders__container {
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .custom-orders__header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .custom-orders__title {
    font-family: var(--font-heading-family);
    font-size: 3rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }
  
  .custom-orders__subtitle {
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    color: {{ settings.color_text_light }};
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .custom-orders__intro {
    background-color: {{ settings.color_cream }};
    padding: 3rem;
    border-radius: 16px;
    margin-bottom: 4rem;
    text-align: center;
  }
  
  .custom-orders__intro-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    margin-bottom: 1.5rem;
  }
  
  .custom-orders__intro-content {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
  }
  
  .custom-orders__intro-content p {
    margin-bottom: 1.5rem;
  }
  
  .custom-orders__process {
    margin-bottom: 4rem;
  }
  
  .custom-orders__process-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .custom-orders__process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    counter-reset: step-counter;
  }
  
  .custom-orders__step {
    position: relative;
    padding: 2rem;
    background-color: white;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    text-align: center;
  }
  
  .custom-orders__step::before {
    counter-increment: step-counter;
    content: counter(step-counter);
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 40px;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    font-weight: 600;
  }
  
  .custom-orders__step-icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ settings.color_cream }};
    border-radius: 50%;
    color: {{ settings.color_dusty_rose }};
    font-size: 1.5rem;
  }
  
  .custom-orders__step-title {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }
  
  .custom-orders__step-content {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.6;
  }
  
  .custom-orders__examples {
    margin-bottom: 4rem;
  }
  
  .custom-orders__examples-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .custom-orders__examples-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  
  .custom-orders__example {
    border-radius: 12px;
    overflow: hidden;
    background-color: white;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease;
  }
  
  .custom-orders__example:hover {
    transform: translateY(-5px);
  }
  
  .custom-orders__example-image-container {
    height: 250px;
    overflow: hidden;
  }
  
  .custom-orders__example-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .custom-orders__example:hover .custom-orders__example-image {
    transform: scale(1.05);
  }
  
  .custom-orders__example-content {
    padding: 1.5rem;
  }
  
  .custom-orders__example-title {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    color: {{ settings.color_text }};
    margin-bottom: 0.75rem;
  }
  
  .custom-orders__example-description {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  
  .custom-orders__example-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .custom-orders__example-tag {
    padding: 0.25rem 0.75rem;
    background-color: {{ settings.color_cream }};
    border-radius: 50px;
    font-family: var(--font-body-family);
    font-size: 0.8rem;
    color: {{ settings.color_text_light }};
  }
  
  .custom-orders__form-section {
    background-color: {{ settings.color_cream }};
    padding: 4rem 2rem;
    border-radius: 16px;
    margin-bottom: 4rem;
  }
  
  .custom-orders__form-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .custom-orders__form {
    max-width: 600px;
    margin: 0 auto;
  }
  
  .custom-orders__form-group {
    margin-bottom: 1.5rem;
  }
  
  .custom-orders__form-label {
    display: block;
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text }};
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
  
  .custom-orders__form-input,
  .custom-orders__form-textarea,
  .custom-orders__form-select {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text }};
    background-color: white;
    transition: all 0.3s ease;
  }
  
  .custom-orders__form-input:focus,
  .custom-orders__form-textarea:focus,
  .custom-orders__form-select:focus {
    outline: none;
    border-color: {{ settings.color_dusty_rose }};
    box-shadow: 0 0 0 3px rgba(232, 180, 184, 0.1);
  }
  
  .custom-orders__form-textarea {
    min-height: 150px;
    resize: vertical;
  }
  
  .custom-orders__form-submit {
    display: block;
    width: 100%;
    padding: 1rem;
    background-color: {{ settings.color_dusty_rose }};
    color: white;
    border: none;
    border-radius: 8px;
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .custom-orders__form-submit:hover {
    background-color: {{ settings.color_dusty_rose | color_darken: 10 }};
  }
  
  .custom-orders__details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }
  
  .custom-orders__detail {
    text-align: center;
    padding: 2rem;
    background-color: white;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }
  
  .custom-orders__detail-icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ settings.color_cream }};
    border-radius: 50%;
    color: {{ settings.color_dusty_rose }};
    font-size: 1.5rem;
  }
  
  .custom-orders__detail-title {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }
  
  .custom-orders__detail-content {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.6;
  }
  
  .custom-orders__faq {
    background-color: {{ settings.color_cream }};
    padding: 4rem 2rem;
    border-radius: 16px;
  }
  
  .custom-orders__faq-title {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    color: {{ settings.color_text }};
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .custom-orders__faq-list {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .custom-orders__faq-item {
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    padding-bottom: 1.5rem;
  }
  
  .custom-orders__faq-item:last-child {
    margin-bottom: 0;
    border-bottom: none;
    padding-bottom: 0;
  }
  
  .custom-orders__faq-question {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    color: {{ settings.color_text }};
    margin-bottom: 0.75rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .custom-orders__faq-answer {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: {{ settings.color_text_light }};
    line-height: 1.6;
    display: none;
  }
  
  .custom-orders__faq-answer.show {
    display: block;
  }
  
  @media screen and (max-width: 768px) {
    .custom-orders-page {
      padding: 2rem 1rem;
    }
    
    .custom-orders__title {
      font-size: 2.5rem;
    }
    
    .custom-orders__intro {
      padding: 2rem 1rem;
    }
    
    .custom-orders__process-steps {
      grid-template-columns: 1fr;
    }
    
    .custom-orders__examples-grid {
      grid-template-columns: 1fr;
    }
    
    .custom-orders__form-section {
      padding: 3rem 1rem;
    }
    
    .custom-orders__details {
      grid-template-columns: 1fr;
    }
    
    .custom-orders__faq {
      padding: 3rem 1rem;
    }
  }
{%- endstyle -%}

<div class="custom-orders-page">
  <div class="custom-orders__container">
    <div class="custom-orders__header">
      <h1 class="custom-orders__title">{{ page.title | default: 'Custom Orders' }}</h1>
      {%- if page.content != blank -%}
        <p class="custom-orders__subtitle">{{ page.content }}</p>
      {%- else -%}
        <p class="custom-orders__subtitle">Have a special story you'd like to bring to life? Let's create something uniquely yours.</p>
      {%- endif -%}
    </div>
    
    <div class="custom-orders__intro">
      <h2 class="custom-orders__intro-title">Bring Your Story to Life</h2>
      <div class="custom-orders__intro-content">
        <p>Every custom order begins with a conversation—a memory, a favorite character, a personal symbol you want to bring to life. Whether it's a cherished story, a meaningful moment, or a special inspiration, we'll work with you to create a one-of-a-kind piece that tells your story.</p>
        <p>Our artisans will guide you through the creative process, from initial sketches to final stitches, ensuring every detail reflects your vision. Each custom piece is made with the same care, intention, and quality as our regular collection, but with the added magic of being uniquely yours.</p>
      </div>
    </div>
    
    <div class="custom-orders__process">
      <h2 class="custom-orders__process-title">The Custom Order Process</h2>
      <div class="custom-orders__process-steps">
        <div class="custom-orders__step">
          <div class="custom-orders__step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3 class="custom-orders__step-title">Initial Consultation</h3>
          <p class="custom-orders__step-content">Share your idea, story, or inspiration. We'll discuss your vision, preferences, and any special requirements.</p>
        </div>
        
        <div class="custom-orders__step">
          <div class="custom-orders__step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"/>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <h3 class="custom-orders__step-title">Design Development</h3>
          <p class="custom-orders__step-content">We create sketches and material samples based on our conversation, refining the design until it's perfect.</p>
        </div>
        
        <div class="custom-orders__step">
          <div class="custom-orders__step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h3 class="custom-orders__step-title">Approval & Timeline</h3>
          <p class="custom-orders__step-content">Review the final design and confirm production schedule. A 50% deposit is required to begin work.</p>
        </div