  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Seasonal Images"
    },
    {
      "type": "image_picker",
      "id": "season_image_1",
      "label": "Spring Collection Image"
    },
    {
      "type": "image_picker",
      "id": "season_image_2",
      "label": "Summer Collection Image"
    },
    {
      "type": "image_picker",
      "id": "season_image_3",
      "label": "Autumn Collection Image"
    },
    {
      "type": "header",
      "content": "Spring Gallery Images"
    },
    {
      "type": "image_picker",
      "id": "spring_image_1",
      "label": "Spring Image 1"
    },
    {
      "type": "image_picker",
      "id": "spring_image_2",
      "label": "Spring Image 2"
    },
    {
      "type": "image_picker",
      "id": "spring_image_3",
      "label": "Spring Image 3"
    },
    {
      "type": "header",
      "content": "Summer Gallery Images"
    },
    {
      "type": "image_picker",
      "id": "summer_image_1",
      "label": "Summer Image 1"
    },
    {
      "type": "image_picker",
      "id": "summer_image_2",
      "label": "Summer Image 2"
    },
    {
      "type": "image_picker",
      "id": "summer_image_3",
      "label": "Summer Image 3"
    }
  ]
}
{% endschema %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Smooth scrolling for season buttons
  const seasonButtons = document.querySelectorAll('.lookbook__season-button');
  seasonButtons.forEach(button => {
    button.addEventListener('click', function(e) {
      e.preventDefault();
      const targetId = this.getAttribute('href');
      const targetElement = document.querySelector(targetId);
      
      if (targetElement) {
        targetElement.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
  
  // Lightbox functionality for gallery images
  const galleryItems = document.querySelectorAll('.lookbook__gallery-item');
  galleryItems.forEach(item => {
    item.addEventListener('click', function() {
      const image = this.querySelector('.lookbook__gallery-image');
      const title = this.querySelector('.lookbook__gallery-item-title')?.textContent || '';
      const description = this.querySelector('.lookbook__gallery-item-description')?.textContent || '';
      
      if (image && image.src) {
        // Create lightbox
        const lightbox = document.createElement('div');
        lightbox.className = 'lookbook-lightbox';
        lightbox.style.cssText = `
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background: rgba(0, 0, 0, 0.9);
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 1000;
          opacity: 0;
          transition: opacity 0.3s ease;
        `;
        
        const lightboxContent = document.createElement('div');
        lightboxContent.style.cssText = `
          max-width: 90%;
          max-height: 90%;
          position: relative;
        `;
        
        const lightboxImage = document.createElement('img');
        lightboxImage.src = image.src;
        lightboxImage.alt = image.alt;
        lightboxImage.style.cssText = `
          max-width: 100%;
          max-height: 70vh;
          object-fit: contain;
          border-radius: 8px;
        `;
        
        const lightboxCaption = document.createElement('div');
        lightboxCaption.style.cssText = `
          color: white;
          text-align: center;
          margin-top: 1rem;
          font-family: var(--font-body-family);
        `;
        
        if (title) {
          const titleElement = document.createElement('h3');
          titleElement.textContent = title;
          titleElement.style.cssText = `
            font-family: var(--font-heading-family);
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
          `;
          lightboxCaption.appendChild(titleElement);
        }
        
        if (description) {
          const descElement = document.createElement('p');
          descElement.textContent = description;
          descElement.style.cssText = `
            font-size: 1rem;
            opacity: 0.8;
          `;
          lightboxCaption.appendChild(descElement);
        }
        
        const closeButton = document.createElement('button');
        closeButton.textContent = '×';
        closeButton.style.cssText = `
          position: absolute;
          top: -40px;
          right: 0;
          background: none;
          border: none;
          color: white;
          font-size: 2rem;
          cursor: pointer;
          width: 40px;
          height: 40px;
          display: flex;
          align-items: center;
          justify-content: center;
        `;
        closeButton.addEventListener('click', () => {
          document.body.removeChild(lightbox);
        });
        
        lightboxContent.appendChild(closeButton);
        lightboxContent.appendChild(lightboxImage);
        lightboxContent.appendChild(lightboxCaption);
        lightbox.appendChild(lightboxContent);
        document.body.appendChild(lightbox);
        
        // Fade in
        setTimeout(() => {
          lightbox.style.opacity = '1';
        }, 10);
        
        // Close on background click
        lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox) {
            document.body.removeChild(lightbox);
          }
        });
        
        // Close on escape key
        document.addEventListener('keydown', function closeOnEscape(e) {
          if (e.key === 'Escape') {
            document.body.removeChild(lightbox);
            document.removeEventListener('keydown', closeOnEscape);
          }
        });
      }
    });
  });
});
</script>

<style>
.lookbook-lightbox {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
</style>